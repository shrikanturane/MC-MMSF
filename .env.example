# ── MCMF environment — copy to .env and set STRONG values for any non-dev deploy ──
# The API refuses to start quietly with placeholder secrets when NODE_ENV=production.

NODE_ENV=production

# ── Secrets (REQUIRED — change all of these) ──────────────────────────────────────
# Seals stored cloud credentials (AES-256-GCM). MUST be 32+ random chars and STABLE
# (rotating it invalidates every saved cloud connection). Generate: openssl rand -hex 32
APP_ENCRYPTION_KEY=change-me-to-a-strong-32char-min-secret
# Optional dedicated JWT signing secret (defaults to APP_ENCRYPTION_KEY). openssl rand -hex 32
AUTH_SECRET=
# Database — do NOT keep the mcmf:mcmf default. Match POSTGRES_PASSWORD below.
DATABASE_URL=postgresql://mcmf:CHANGE_ME_STRONG@db:5432/mcmf
POSTGRES_PASSWORD=CHANGE_ME_STRONG
# Machine-to-machine key guest agents present when pushing telemetry.
AGENT_KEY=change-me-agent-key

# ── Web / CORS ────────────────────────────────────────────────────────────────────
WEB_ORIGIN=https://your-host
ALLOW_ALL_ORIGINS=0
NEXT_PUBLIC_API_URL=/api

# ── First-run data ────────────────────────────────────────────────────────────────
# Clean install by default (no sample cloud accounts). Set to 1 to load the "Acme" demo
# dataset for a quick showcase. The default admin (admin@mcmf.local / Admin@123 — change it
# on first login) is created regardless of this flag.
DEMO_SEED=0

# ── TLS certs ─────────────────────────────────────────────────────────────────────
# Host directory bind-mounted into nginx at /etc/nginx/certs (expects fullchain.pem + privkey.pem).
CERT_DIR=./certs

# ── Email (SMTP) — for alert email delivery ───────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── WhatsApp (Meta Cloud API) — for WhatsApp alerts ───────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── SSO (optional) ────────────────────────────────────────────────────────────────
SSO_BASE_URL=https://your-host
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common

# ── AI / cluster / logs ───────────────────────────────────────────────────────────
AI_PROVIDER=free            # free (native) | anthropic | openai | gemini | ollama | local
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=
AI_MODEL=
CLICKHOUSE_URL=http://clickhouse:8123
LOG_TTL_DAYS=30

# ── Cloud provisioning safety ───────────────────────────────────────────────────────
# Leave unset to keep live provisioning in plan-only/dry-run. Set to 1 to allow real apply.
PROVISION_EXEC=
