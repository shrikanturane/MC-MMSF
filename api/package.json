{
  "name": "mcmf-api",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "MCMF multi-cloud management REST API",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:cov": "jest --coverage"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": ".",
    "roots": ["<rootDir>/src", "<rootDir>/test"],
    "setupFiles": ["reflect-metadata"],
    "testMatch": ["**/*.spec.ts"],
    "moduleFileExtensions": ["ts", "js", "json"],
    "collectCoverageFrom": [
      "src/auth/jwt.ts",
      "src/common/finops-carbon.ts",
      "src/common/host-identity.ts"
    ],
    "coverageThreshold": {
      "global": { "lines": 70, "statements": 70, "functions": 65, "branches": 50 }
    }
  },
  "dependencies": {
    "acme-client": "^5.4.0",
    "@aws-sdk/client-cloudwatch": "^3.658.0",
    "@aws-sdk/client-cost-explorer": "^3.658.0",
    "@aws-sdk/client-ec2": "^3.658.0",
    "@aws-sdk/client-ec2-instance-connect": "^3.658.0",
    "@aws-sdk/client-iam": "^3.658.0",
    "@aws-sdk/client-rds": "^3.658.0",
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/client-securityhub": "^3.658.0",
    "@aws-sdk/client-sts": "^3.658.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.20.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "geoip-lite": "^1.4.10",
    "guacamole-lite": "^1.2.0",
    "jose": "^4.15.9",
    "net-snmp": "^3.11.2",
    "nodemailer": "^6.9.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.16",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@types/ssh2": "^1.15.1",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
