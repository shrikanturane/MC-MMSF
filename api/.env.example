# MCMF API — local dev env. Copy to api/.env. For the full stack use the root .env instead.

# ── REQUIRED secret (no default — the API refuses to start without it) ──────────────
# Seals stored cloud credentials (AES-256-GCM) + signs auth tokens. 32+ random chars, STABLE.
# Generate: openssl rand -hex 32
APP_ENCRYPTION_KEY=change-me-to-a-strong-32char-min-secret
# Optional dedicated JWT signing secret (defaults to APP_ENCRYPTION_KEY). openssl rand -hex 32
AUTH_SECRET=

# ── Database ────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://mcmf:mcmf@localhost:5432/mcmf"

# ── Server / web ──────────────────────────────────────────────────────────────────────
PORT=4000
WEB_ORIGIN=http://localhost:3000

# ── First-run data ────────────────────────────────────────────────────────────────────
# 0 (default) = clean install, no sample cloud accounts. 1 = load the "Acme" demo dataset.
DEMO_SEED=0

# ── Optional integrations (all safe to leave blank) ────────────────────────────────────
# Machine-to-machine key guest agents present (defaults to a slice of APP_ENCRYPTION_KEY).
AGENT_KEY=
# Live cloud PROVISIONING execution — leave unset to keep plan-only/dry-run. Set to 1 to allow real apply.
PROVISION_EXEC=
# ClickHouse (log + metrics store). Defaults to http://clickhouse:8123 in compose.
CLICKHOUSE_URL=
# AI provider (optional): AI_PROVIDER=ollama|anthropic|openai|gemini|local. Keys per provider:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=
AI_MODEL=
